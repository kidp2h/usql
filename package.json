{
  "name": "usql",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "author": {
    "name": "kidp2h",
    "url": "https://thinh.world",
    "email": "nthinh.dev@gmail.com"
  },
  "description": "SQL editor for developer",
  "scripts": {
    "dev": "next dev",
    "dev:electron": "bun scripts/electron-dev.mjs",
    "build": "next build",
    "start": "next start",
    "dist": "bun run build && electron-builder",
    "dist:publish": "dotenv -e .env -- electron-builder --publish always",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lint": "^6.9.5",
    "@uiw/codemirror-themes-all": "^4.25.9",
    "@uiw/react-codemirror": "^4.25.9",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "node-sql-parser": "^5.4.0",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.19",
    "@types/electron": "^1.6.12",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "electron-icon-builder": "^2.0.1",
    "lucide-react": "^0.575.0",
    "monaco-editor": "^0.55.1",
    "monaco-sql-languages": "^0.15.1",
    "monaco-themes": "^0.4.8",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pgsql-ast-parser": "^12.0.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-icons": "^5.6.0",
    "react-resizable-panels": "^4.6.2",
    "rimraf": "^6.1.3",
    "shadcn": "^3.8.4",
    "sonner": "^2.0.7",
    "sql-formatter": "^15.4.10",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "build": {
    "appId": "com.usql.app",
    "productName": "Universe SQL",
    "asar": true,
    "compression": "normal",
    "artifactName": "uSQL-v${version}.${ext}",
    "icon": "assets/icon.png",
    "publish": [
      {
        "provider": "github",
        "owner": "kidp2h",
        "repo": "usql"
      }
    ],
    "files": [
      "out/**",
      "electron/**",
      "package.json",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsx",
      "!**/*.mjs"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/icons/win/icon.ico",
      "target": [
        "zip"
      ]
    },
    "mac": {
      "icon": "assets/icons/mac/icon.icns",
      "target": [
        "zip"
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        "zip"
      ]
    }
  }
}